generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model archives_export {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  demande_par       String?       @db.Uuid
  periode_debut     DateTime?     @db.Date
  periode_fin       DateTime?     @db.Date
  format            String?
  horodatage_export DateTime?     @default(now()) @db.Timestamptz(6)
  hash_fichier      String?
  utilisateurs      utilisateurs? @relation(fields: [demande_par], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model boutiques {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nom                 String
  siret               String?
  adresse             String?
  cree_le             DateTime?             @default(now()) @db.Timestamptz(6)
  nom_gerant          String?
  email_gerant        String?
  telephone_gerant    String? 
  slug                String?   @unique
  domaine_custom      String?   @unique
  domaine_boutique    String?   @unique
  logo_url            String?
  telephone           String?
  abonnements_saas    abonnements_saas?
  arrivages           arrivages[]
  categories_boutique categories_boutique[]
  clotures            clotures[]
  locations           locations[]
  mouvements_stock    mouvements_stock[]
  stock               stock[]
  tickets             tickets[]
  utilisateurs        utilisateurs[]
  config_creneaux_essayage config_creneaux_essayage[]
  config_boutique           config_boutique?
  pages_boutique            pages_boutique[]
  resend_domain_id          String?
  resend_domain_statut      String?
  resend_api_key            String?
