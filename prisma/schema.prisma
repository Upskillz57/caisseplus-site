/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model stock {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  variante_id       String            @db.Uuid
  boutique_id       String            @db.Uuid
  quantite          Int               @default(0)
  mis_a_jour_le     DateTime?         @default(now()) @db.Timestamptz(6)
  boutiques         boutiques         @relation(fields: [boutique_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  variantes_produit variantes_produit @relation(fields: [variante_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([variante_id, boutique_id])
  @@index([boutique_id])
  @@index([variante_id])
}

