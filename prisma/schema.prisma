  mode_service             String[]  @default([])
  prix_ht                  Decimal                   @db.Decimal(10, 2)
  taux_tva                 Decimal                   @default(20.00) @db.Decimal(4, 2)
  actif                    Boolean?                  @default(true)
  cree_le                  DateTime?                 @default(now()) @db.Timestamptz(6)
  mode                     String                    @default("vente")
  sous_categorie_id        String?                   @db.Uuid
  media_produit            media_produit[]
  sous_categories_boutique sous_categories_boutique? @relation(fields: [sous_categorie_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  categories_boutique      categories_boutique?      @relation(fields: [categorie_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
