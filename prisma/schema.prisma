model avis {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  produit_id  String   @db.Uuid
  client_id   String   @db.Uuid
  note        Int
  commentaire String?
  cree_le     DateTime @default(now())
 
  produit     produits @relation(fields: [produit_id], references: [id], onDelete: Cascade)
  client      clients  @relation(fields: [client_id],  references: [id], onDelete: Cascade)
 
  @@unique([produit_id, client_id])
  @@index([produit_id])
}
 
model panier_items {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  client_id   String    @db.Uuid
  boutique_id String    @db.Uuid
  produit_id  String    @db.Uuid
  variante_id String    @db.Uuid
  quantite    Int       @default(1)
  date_debut  DateTime?
  date_fin    DateTime?
  cree_le     DateTime  @default(now())
 
  client      clients   @relation(fields: [client_id],   references: [id], onDelete: Cascade)
  produit     produits  @relation(fields: [produit_id],  references: [id], onDelete: Cascade)
  variante    variantes_produit @relation(fields: [variante_id], references: [id], onDelete: Cascade)

  @@index([client_id])
  @@index([boutique_id])
}

model caution_tokens {
