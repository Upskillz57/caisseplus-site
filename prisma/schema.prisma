  categorie       categories_boutique? @relation(fields: [categorie_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  sections        sections_page[]
}

model sections_page {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  page_id     String    @db.Uuid
  type        String
  ordre       Int       @default(0)
  contenu     Json      @default("{}")
  cree_le     DateTime? @default(now()) @db.Timestamptz(6)
  pages       pages_boutique @relation(fields: [page_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

